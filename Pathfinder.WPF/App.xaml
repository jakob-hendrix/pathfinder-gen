<Application x:Class="Pathfinder.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Pathfinder.WPF.Views"
             xmlns:viewModels="clr-namespace:Pathfinder.WPF.ViewModels">

    <!--Load any common app-wide resources here-->
    <Application.Resources>
        <ResourceDictionary>

            <!--Styling-->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/CommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!--View & ViewModel Linkages -->
            <DataTemplate DataType="{x:Type viewModels:HomeViewModel}">
                <views:HomeView/>
            </DataTemplate>

        </ResourceDictionary>
    </Application.Resources>
</Application>
